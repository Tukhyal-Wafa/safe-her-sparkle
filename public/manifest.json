{
  "name": "SafeGuard — Professional Women Safety Platform",
  "short_name": "SafeGuard",
  "description": "Enterprise-grade women safety platform with advanced SOS, real-time location tracking, video recording, and emergency response system.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#f0fdf4",
  "theme_color": "#22c55e",
  "categories": ["safety", "lifestyle", "utilities"],
  "icons": [
    { 
      "src": "/icons/icon.svg", 
      "sizes": "any", 
      "type": "image/svg+xml", 
      "purpose": "any maskable" 
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/home.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ],
  "shortcuts": [
    {
      "name": "Emergency SOS",
      "short_name": "SOS",
      "description": "Activate emergency SOS",
      "url": "/?action=sos",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "96x96" }]
    },
    {
      "name": "Contacts",
      "short_name": "Contacts",
      "description": "Manage emergency contacts",
      "url": "/contacts",
      "icons": [{ "src": "/icons/icon.svg", "sizes": "96x96" }]
    }
  ],
  "permissions": [
    "geolocation",
    "camera",
    "microphone"
  ],
  "prefer_related_applications": false
}
